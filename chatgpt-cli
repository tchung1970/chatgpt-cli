#!/usr/bin/env python3
"""CLI ChatGPT client for macOS with web search."""

import json
import os
import select
import sys
import termios
import readline
from pathlib import Path

from openai import OpenAI
from rich.console import Console
from rich.markdown import Markdown

# Load API key from ~/.env
def load_env():
    env_file = Path.home() / ".env"
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, value = line.partition("=")
                os.environ[key.strip()] = value.strip()

load_env()

# Disable bracketed paste — libedit on macOS doesn't handle it properly
readline.parse_and_bind("set enable-bracketed-paste off")

client = OpenAI()
console = Console()

MODEL = os.environ.get("CHATGPT_MODEL", "gpt-5.4-mini")
SYSTEM_PROMPT = "You are a helpful assistant."
TOOLS = [{"type": "web_search_preview"}]
CONFIG_FILE = Path.home() / ".chatgpt-cli.json"


def get_user_name():
    """Load or prompt for the user's first name, saved to ~/.chatgpt-cli.json."""
    config = {}
    if CONFIG_FILE.exists():
        config = json.loads(CONFIG_FILE.read_text())
    if "name" in config:
        return config["name"]
    name = input("Enter your first name: ").strip()
    if not name:
        name = "User"
    config["name"] = name
    CONFIG_FILE.write_text(json.dumps(config))
    return name


def get_response_text(response):
    """Extract text from a Responses API response."""
    text = ""
    for item in response.output:
        if item.type == "message":
            for part in item.content:
                if part.type == "output_text":
                    text += part.text
    return text


def build_input(history, user_msg):
    """Build input for the Responses API from conversation history."""
    inputs = []
    for msg in history:
        inputs.append(msg)
    inputs.append({"role": "user", "content": user_msg})
    return inputs


def chat():
    history = [{"role": "system", "content": SYSTEM_PROMPT}]

    name = get_user_name()
    console.print(f"[bold green]Hi {name}, How can I help you?[/]")
    console.print(f"[dim]Model: {MODEL} | Type q, quit, or exit to quit[/]\n")

    while True:
        try:
            user_input = input("> ").strip()
        except (KeyboardInterrupt, EOFError):
            console.print("\n[dim]Goodbye![/]")
            break

        # Backslash continuation: line ending with \ prompts for more
        while user_input.endswith("\\"):
            user_input = user_input[:-1]
            try:
                user_input += "\n" + input("... ")
            except (KeyboardInterrupt, EOFError):
                break

        # Auto-detect pasted multi-line input via raw fd reads
        fd = sys.stdin.fileno()
        extra_chunks = []
        while select.select([fd], [], [], 0.15)[0]:
            chunk = os.read(fd, 65536)
            if not chunk:
                break
            extra_chunks.append(chunk.decode())
        if extra_chunks:
            extra_raw = "".join(extra_chunks)
            user_input = user_input + "\n" + extra_raw.rstrip("\n")
            total_lines = user_input.count("\n") + 1
            # Flush any remaining stdin data from the paste
            termios.tcflush(fd, termios.TCIFLUSH)
            # Move cursor up past all echoed lines and clear to end of screen
            echo_lines = extra_raw.count("\n") + 1
            for _ in range(echo_lines):
                sys.stdout.write("\x1b[A")
            sys.stdout.write(f"\r\x1b[2K> [Pasted text +{total_lines} lines]\x1b[J\n")
            sys.stdout.flush()
            # Prompt for additional input before submitting
            try:
                additional = input("> ").strip()
                if additional:
                    user_input = user_input + "\n" + additional
            except (KeyboardInterrupt, EOFError):
                pass

        # Manual multi-line input mode: /paste to enter, /end to submit
        if user_input.lower() == "/paste":
            console.print("[dim]Multi-line mode. Type your text, then /end to submit.[/]")
            lines = []
            try:
                while True:
                    line = input("... ")
                    if line.strip().lower() == "/end":
                        break
                    lines.append(line)
            except (KeyboardInterrupt, EOFError):
                console.print("\n[dim]Multi-line input cancelled.[/]")
                continue
            user_input = "\n".join(lines).strip()

        if not user_input:
            continue

        if user_input.lower() in ("q", "quit", "exit"):
            console.print("[dim]Goodbye![/]")
            break

        # Commands
        if user_input.startswith("/"):
            cmd = user_input.lower()
            if cmd == "/clear":
                history = [{"role": "system", "content": SYSTEM_PROMPT}]
                console.print("[dim]Conversation cleared.[/]\n")
                continue
            elif cmd == "/help":
                console.print("[dim]/clear  - Reset conversation\n/model  - Show current model\n/paste  - Multi-line input mode\n\\\\      - Continue input on next line[/]\n")
                continue
            elif cmd == "/model":
                console.print(f"[dim]Model: {MODEL}[/]\n")
                continue

        inputs = build_input(history, user_input)

        try:
            console.print()
            with console.status("[bold cyan]Thinking...", spinner="dots"):
                response = client.responses.create(
                    model=MODEL,
                    input=inputs,
                    tools=TOOLS,
                )

            response_text = get_response_text(response)
            history.append({"role": "user", "content": user_input})
            history.append({"role": "assistant", "content": response_text})
            console.print(Markdown(response_text))
            console.print()

        except Exception as e:
            console.print(f"[bold red]Error:[/] {e}\n")

    return


if __name__ == "__main__":
    # Allow one-shot mode: chatgpt "question here"
    if len(sys.argv) > 1:
        query = " ".join(sys.argv[1:])
        inputs = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": query},
        ]
        try:
            response = client.responses.create(
                model=MODEL,
                input=inputs,
                tools=TOOLS,
            )
            text = get_response_text(response)
            console.print(Markdown(text))
        except Exception as e:
            console.print(f"[bold red]Error:[/] {e}")
            sys.exit(1)
    else:
        chat()
